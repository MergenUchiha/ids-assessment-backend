generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Experiment {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  runs        Run[]
}

model Run {
  id            String    @id @default(uuid())
  experimentId  String
  scenarioId    String?
  idsProfileId  String?
  status        RunStatus @default(QUEUED)
  startedAt     DateTime?
  finishedAt    DateTime?
  attackSuccess Boolean?

  // paths to artifacts
  evePath    String?
  msfLogPath String?

  experiment Experiment  @relation(fields: [experimentId], references: [id])
  scenario   Scenario?   @relation(fields: [scenarioId], references: [id])
  idsProfile IdsProfile? @relation(fields: [idsProfileId], references: [id])

  attackEvents AttackEvent[]
  alerts       Alert[]
  metrics      Metric?
}

model Alert {
  id        String   @id @default(uuid())
  runId     String
  timestamp DateTime
  signature String
  severity  Int
  srcIp     String
  destIp    String
  raw       Json
  run       Run      @relation(fields: [runId], references: [id])
}

model Metric {
  id    String @id @default(uuid())
  runId String @unique

  tp Int @default(0)
  fp Int @default(0)
  fn Int @default(0)

  precision Float?
  recall    Float?
  f1        Float?
  latencyMs Int?

  run Run @relation(fields: [runId], references: [id])
}

model Scenario {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  msfModule          String
  payload            String?
  rport              Int?
  // ожидаемые сигнатуры IDS (упрощенно) - для сопоставления
  expectedSignatures String[] @default([])
  createdAt          DateTime @default(now())

  runs Run[]
}

model IdsProfile {
  id        String   @id @default(uuid())
  name      String   @unique
  // путь/идентификатор набора правил (для диплома достаточно string)
  ruleset   String
  createdAt DateTime @default(now())

  runs Run[]
}

model AttackEvent {
  id        String   @id @default(uuid())
  runId     String
  type      String // attack_start, attack_end, attack_success, attack_fail
  timestamp DateTime @default(now())
  data      Json?

  run Run @relation(fields: [runId], references: [id])
}

enum RunStatus {
  QUEUED
  RUNNING
  FINISHED
  FAILED
}
