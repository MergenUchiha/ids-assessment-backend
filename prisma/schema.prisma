generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AttackScenario {
  id          String   @id @default(uuid())
  name        String
  description String
  exploitType String
  targetIP    String
  targetOS    String
  targetPort  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      String   @default("draft") // draft, ready, running, completed
  tests       Test[]

  @@map("attack_scenarios")
}

model Test {
  id               String          @id @default(uuid())
  scenarioId       String
  scenario         AttackScenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  startedAt        DateTime        @default(now())
  finishedAt       DateTime?
  status           String          @default("running") // running, completed, failed
  totalAttacks     Int             @default(0)
  detectedAttacks  Int             @default(0)
  missedAttacks    Int             @default(0)
  falsePositives   Int             @default(0)
  results          TestResult[]

  @@map("tests")
}

model TestResult {
  id             String   @id @default(uuid())
  testId         String
  test           Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  attackType     String
  exploitName    String
  idsDetected    Boolean
  detectionTime  Int?
  falsePositive  Boolean  @default(false)
  severity       String   // low, medium, high, critical
  timestamp      DateTime @default(now())
  sourceIP       String
  targetIP       String
  protocol       String

  @@map("test_results")
}

model IDSConfiguration {
  id          String   @id @default(uuid())
  name        String
  type        String   // snort, suricata
  version     String
  rules       Int
  sensitivity String   // low, medium, high
  status      String   @default("inactive") // active, inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ids_configurations")
}

model LabEnvironment {
  id        String   @id @default(uuid())
  name      String
  type      String   // attacker, target, ids
  ip        String   @unique
  os        String
  status    String   @default("offline") // online, offline, busy
  cpu       Float    @default(0)
  memory    Float    @default(0)
  network   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lab_environments")
}

model Report {
  id              String   @id @default(uuid())
  name            String
  type            String   // summary, detailed, comparative
  format          String   // pdf, csv, json
  dateRange       String
  testsIncluded   Int      @default(0)
  fileSize        String?
  filePath        String?
  createdAt       DateTime @default(now())

  @@map("reports")
}